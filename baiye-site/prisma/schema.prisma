generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Member {
  id         String   @id @default(cuid())
  nickname   String
  avatar     String?
  role       String   @default("小猫咪") // 猫老大, 大猫, 橘猫, 小猫咪
  profession String?  // 铲屎官, 猫粮官, 摄影师, 云吸猫 等
  level      Int      @default(1)
  power      Int      @default(0) // 喵力值
  intro      String?  // 个人简介
  gameImage  String?  @map("game_image") // 少冬瓜角色图片
  isPublic   Boolean  @default(true) @map("is_public")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("members")
}


